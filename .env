# PostgreSQL
POSTGRES_DB=agrohub
POSTGRES_USER=agrohub
POSTGRES_PASSWORD=changeme

# App
SECRET_KEY=change-me-in-production-very-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=agrohub

# Yandex Maps (Routing Matrix API)
YANDEX_API_KEY=

# Environment
ENVIRONMENT=development

# Frontend (Vite)
# When running frontend outside Docker, proxy target:
VITE_API_TARGET=http://localhost:8000
